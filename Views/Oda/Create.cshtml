@model OtelRezervasyon.Models.Oda

@{
    ViewData["Title"] = "Yeni Oda Ekle";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h4>Yeni Oda Ekle</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="OdaNumarasi" class="form-label"></label>
                            <input asp-for="OdaNumarasi" class="form-control" placeholder="Örn: 101" />
                            <span asp-validation-for="OdaNumarasi" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="OdaTipi" class="form-label"></label>
                            <select asp-for="OdaTipi" class="form-select">
                                <option value="">-- Oda Tipi Seçiniz --</option>
                                <option value="Standart">Standart</option>
                                <option value="Deluxe">Deluxe</option>
                                <option value="Suite">Suite</option>
                                <option value="Aile Odası">Aile Odası</option>
                            </select>
                            <span asp-validation-for="OdaTipi" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Fiyat" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">₺</span>
                                <input asp-for="Fiyat" class="form-control" placeholder="Örn: 500.00" />
                            </div>
                            <span asp-validation-for="Fiyat" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Geri Dön
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
