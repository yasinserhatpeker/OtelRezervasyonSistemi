@model OtelRezervasyon.Models.Rezervasyon

@{
    ViewData["Title"] = "Rezervasyon Düzenle";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h4>Rezervasyon Düzenle</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        <input type="hidden" asp-for="RezervasyonId" />

                        <div class="mb-3">
                            <label asp-for="MusteriId" class="form-label">Müşteri</label>
                            <select asp-for="MusteriId" class="form-select" asp-items="ViewBag.MusteriId">
                                <option value="">-- Müşteri Seçiniz --</option>
                            </select>
                            <span asp-validation-for="MusteriId" class="text-danger"></span>
                            <small class="form-text text-muted">
                                * Sadece rezervasyonu olmayan müşteriler listelenmektedir.
                            </small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="OdaId" class="form-label">Oda</label>
                            <select asp-for="OdaId" class="form-select" asp-items="ViewBag.OdaId">
                                <option value="">-- Oda Seçiniz --</option>
                            </select>
                            <span asp-validation-for="OdaId" class="text-danger"></span>
                            <small class="form-text text-muted">
                                * Sadece rezerve edilmemiş odalar listelenmektedir.
                            </small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="GirisTarihi" class="form-label"></label>
                            <input asp-for="GirisTarihi" type="date" class="form-control" />
                            <span asp-validation-for="GirisTarihi" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CikisTarihi" class="form-label"></label>
                            <input asp-for="CikisTarihi" type="date" class="form-control" />
                            <span asp-validation-for="CikisTarihi" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Geri Dön
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-save"></i> Güncelle
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
