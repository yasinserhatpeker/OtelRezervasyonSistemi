@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="text-center">
    <div class="jumbotron bg-light p-5 rounded-3 shadow-lg mb-5">
        <h1 class="display-4 fw-bold text-primary">
            <i class="bi bi-building"></i> Otel Rezervasyon Sistemi
        </h1>
        <p class="lead mt-4 text-muted">
            Otel işletmenizi kolayca yönetin. Odalarınızı, müşterilerinizi ve rezervasyonlarınızı tek bir yerden takip edin.
        </p>
        <hr class="my-4">
        <p class="text-secondary">
            Hızlı erişim için aşağıdaki bölümlerden birini seçin
        </p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 hover-card">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <i class="bi bi-door-open display-1 text-primary"></i>
                    </div>
                    <h3 class="card-title fw-bold mb-3">Odalar</h3>
                    <p class="card-text text-muted mb-4">
                        Otel odalarını görüntüleyin, yeni oda ekleyin veya mevcut oda bilgilerini güncelleyin.
                    </p>
                    <a asp-controller="Oda" asp-action="Index" class="btn btn-primary btn-lg px-4 rounded-pill">
                        <i class="bi bi-arrow-right-circle"></i> Odaları Görüntüle
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 hover-card">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <i class="bi bi-people display-1 text-success"></i>
                    </div>
                    <h3 class="card-title fw-bold mb-3">Müşteriler</h3>
                    <p class="card-text text-muted mb-4">
                        Müşteri kayıtlarını yönetin, yeni müşteri ekleyin veya müşteri bilgilerini düzenleyin.
                    </p>
                    <a asp-controller="Musteri" asp-action="Index" class="btn btn-success btn-lg px-4 rounded-pill">
                        <i class="bi bi-arrow-right-circle"></i> Müşterileri Görüntüle
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 hover-card">
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <i class="bi bi-calendar-check display-1 text-danger"></i>
                    </div>
                    <h3 class="card-title fw-bold mb-3">Rezervasyonlar</h3>
                    <p class="card-text text-muted mb-4">
                        Rezervasyonları takip edin, yeni rezervasyon oluşturun veya mevcut rezervasyonları yönetin.
                    </p>
                    <a asp-controller="Rezervasyon" asp-action="Index" class="btn btn-danger btn-lg px-4 rounded-pill">
                        <i class="bi bi-arrow-right-circle"></i> Rezervasyonları Görüntüle
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Otel Galerisi Bölümü -->
    <div class="mt-5">
        <div class="text-center mb-4">
            <h2 class="fw-bold">
                <i class="bi bi-images text-primary"></i> Otel Galerimiz
            </h2>
            <p class="text-muted">Lüks ve konforlu otel odalarımızı keşfedin</p>
        </div>

        <div id="hotelCarousel" class="carousel slide shadow-lg rounded-3 overflow-hidden" data-bs-ride="carousel">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#hotelCarousel" data-bs-slide-to="0" class="active"></button>
                <button type="button" data-bs-target="#hotelCarousel" data-bs-slide-to="1"></button>
                <button type="button" data-bs-target="#hotelCarousel" data-bs-slide-to="2"></button>
                <button type="button" data-bs-target="#hotelCarousel" data-bs-slide-to="3"></button>
                <button type="button" data-bs-target="#hotelCarousel" data-bs-slide-to="4"></button>
            </div>
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=1200&h=600&fit=crop"
                         class="d-block w-100 carousel-img" alt="Luxury Hotel Lobby">
                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-3">
                        <h5>Lüks Otel Lobisi</h5>
                        <p>Modern ve şık tasarımlarımızla sizi karşılıyoruz</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?w=1200&h=600&fit=crop"
                         class="d-block w-100 carousel-img" alt="Hotel Room">
                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-3">
                        <h5>Konforlu Odalar</h5>
                        <p>Her detayı düşünülmüş, rahat ve ferah odalar</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="https://images.unsplash.com/photo-1590490360182-c33d57733427?w=1200&h=600&fit=crop"
                         class="d-block w-100 carousel-img" alt="Hotel Pool">
                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-3">
                        <h5>Havuz ve Spa</h5>
                        <p>Dinlenme ve eğlence için harika imkanlar</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="https://images.unsplash.com/photo-1578683010236-d716f9a3f461?w=1200&h=600&fit=crop"
                         class="d-block w-100 carousel-img" alt="Hotel Suite">
                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-3">
                        <h5>Suit Odalar</h5>
                        <p>Geniş ve lüks suit odalarımızla kendinizi özel hissedin</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?w=1200&h=600&fit=crop"
                         class="d-block w-100 carousel-img" alt="Hotel Restaurant">
                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-3">
                        <h5>Restoran ve Bar</h5>
                        <p>Dünya mutfağından lezzetler ve premium içecekler</p>
                    </div>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#hotelCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Önceki</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#hotelCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Sonraki</span>
            </button>
        </div>
    </div>

    <!-- Küçük Galeri Grid -->
    <div class="row g-3 mt-4">
        <div class="col-md-3 col-sm-6">
            <div class="gallery-item">
                <img src="https://images.unsplash.com/photo-1571896349842-33c89424de2d?w=400&h=300&fit=crop"
                     class="img-fluid rounded shadow-sm" alt="Hotel View 1">
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="gallery-item">
                <img src="https://images.unsplash.com/photo-1596436889106-be35e843f974?w=400&h=300&fit=crop"
                     class="img-fluid rounded shadow-sm" alt="Hotel View 2">
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="gallery-item">
                <img src="https://images.unsplash.com/photo-1564501049412-61c2a3083791?w=400&h=300&fit=crop"
                     class="img-fluid rounded shadow-sm" alt="Hotel View 3">
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="gallery-item">
                <img src="https://images.unsplash.com/photo-1584132967334-10e028bd69f7?w=400&h=300&fit=crop"
                     class="img-fluid rounded shadow-sm" alt="Hotel View 4">
            </div>
        </div>
    </div>

    <div class="mt-5 p-4 bg-light rounded-3 shadow-sm">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h4 class="mb-2">
                    <i class="bi bi-info-circle text-primary"></i> Sistem Özellikleri
                </h4>
                <p class="text-muted mb-0">
                    Modern ve kullanıcı dostu arayüz ile otel yönetim süreçlerinizi dijitalleştirin.
                </p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <span class="badge bg-primary p-3 rounded-pill">
                    <i class="bi bi-star-fill"></i> ASP.NET MVC
                </span>
            </div>
        </div>
    </div>
</div>

<style>
    .jumbotron {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }

    .hover-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .hover-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important;
    }

    .card-body i.display-1 {
        font-size: 5rem;
    }

    /* Carousel Stilleri */
    .carousel-img {
        height: 500px;
        object-fit: cover;
    }

    .carousel-caption {
        bottom: 30px;
    }

    /* Galeri Grid Stilleri */
    .gallery-item {
        position: relative;
        overflow: hidden;
        border-radius: 0.5rem;
        transition: transform 0.3s ease;
    }

    .gallery-item:hover {
        transform: scale(1.05);
        cursor: pointer;
    }

    .gallery-item img {
        width: 100%;
        height: 250px;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .gallery-item:hover img {
        transform: scale(1.1);
    }

    /* Responsive tasarım için */
    @@media (max-width: 768px) {
        .carousel-img {
            height: 300px;
        }

        .gallery-item img {
            height: 200px;
        }
    }
</style>
